# In-container gRPC listen address (see docker-compose.yml).
# MAILER_WORKER_GRPC_LISTEN=:50054

# Host port mapped to container 50054 (avoid clashing with push 59203 / search 59202).
# MAILER_WORKER_GRPC_HOST_PORT=59204

# Optional shared secret for gRPC metadata (must match many_faces_backend Mail:WorkerAuthToken when set).
# MAILER_WORKER_EXPECTED_TOKEN=

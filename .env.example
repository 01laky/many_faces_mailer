# In-container gRPC listen address (see docker-compose.yml).
# MAILER_WORKER_GRPC_LISTEN=:50054

# Host port mapped to container 50054 (avoid clashing with push 59203 / search 59202).
# MAILER_WORKER_GRPC_HOST_PORT=59204

# Optional shared secret for gRPC metadata (must match many_faces_backend Mail:WorkerAuthToken when set).
# MAILER_WORKER_EXPECTED_TOKEN=

# Optional gRPC TLS (both cert + key required together). Optional mTLS client CA PEM.
# MAILER_WORKER_GRPC_TLS_CERT_FILE=
# MAILER_WORKER_GRPC_TLS_KEY_FILE=
# MAILER_WORKER_GRPC_MTLS_CLIENT_CA_FILE=

# Dev-only grpcurl reflection (do not enable on shared networks).
# MAILER_WORKER_GRPC_REFLECTION=1

# SMTP relay / sink (Mailpit defaults in docker-compose.yml).
# MAILER_SMTP_HOST=mailpit
# MAILER_SMTP_PORT=1025
# MAILER_SMTP_STARTTLS=false
# MAILER_SMTP_USER=
# MAILER_SMTP_PASSWORD=

# MIME From header (transactional identity).
# MAILER_FROM_EMAIL=no-reply@example.invalid
# MAILER_FROM_DISPLAY_NAME=Many Faces Dev

# Fallback BCP 47 when the RPC carries an unknown locale tag.
# MAILER_DEFAULT_LOCALE=en

# Mailpit host port maps (see docker-compose.yml).
# MAILPIT_SMTP_HOST_PORT=51025
# MAILPIT_UI_HOST_PORT=58025

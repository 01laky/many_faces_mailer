{
	"search.exclude": {
		"**/build": true,
		"**/.gradle": true
	},
	"files.watcherExclude": {
		"**/build": true,
		"**/.gradle": true
	},
	"editor.formatOnSave": true,
	"editor.tabSize": 4,
	"editor.insertSpaces": false,
	"editor.detectIndentation": false,
	"[java]": {
		"editor.tabSize": 4
	},
	"[kotlin]": {
		"editor.tabSize": 4
	}
}

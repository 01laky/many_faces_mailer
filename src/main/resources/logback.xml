<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!--
      Structured stdout for container log collectors (Docker / k8s). Pattern includes level + logger + message;
      stack traces remain on separate lines for grep-friendly triage.
    -->
    <appender name="STDOUT" class="ch.qos.logback.core.ConsoleAppender">
        <encoder class="net.logstash.logback.encoder.LogstashEncoder">
            <customFields>{"service":"many_faces_mailer"}</customFields>
        </encoder>
    </appender>
    <root level="INFO">
        <appender-ref ref="STDOUT"/>
    </root>
</configuration>
